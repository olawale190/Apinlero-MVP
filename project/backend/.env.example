# Àpínlẹ̀rọ Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-url.railway.app

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Knowledge-graph modules also accept SUPABASE_SERVICE_KEY as a fallback
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Security: Delivery Token Secret (required)
# Generate with: openssl rand -hex 32
DELIVERY_TOKEN_SECRET=

# Cloudinary Configuration (required for AI image matching)
# Enable the Google Auto Tagging add-on in Cloudinary dashboard (Settings → Add-ons)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio WhatsApp Configuration (for Knowledge Graph webhook)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Anthropic Claude API (for intent classification)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Neo4j Configuration (for Knowledge Graph)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
