# ================================================
# Àpínlẹ̀rọ Security Environment Variables
# ================================================
#
# This file contains all security-related environment variables
# for the 4-layer security stack. Copy these to your .env.local
# and Railway/Vercel environment variables.
#
# NEVER commit actual secrets to git!
# ================================================

# ===========================
# Layer 1: Secret Scanning & Code Security
# ===========================

# Snyk API Token
# Get from: https://app.snyk.io/account
SNYK_TOKEN=

# ===========================
# Layer 3: Runtime Monitoring & Error Tracking
# ===========================

# Sentry DSN (Frontend)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Sentry Auth Token (for releases and sourcemaps)
# Get from: https://sentry.io → Settings → Account → API → Auth Tokens
SENTRY_AUTH_TOKEN=

# ===========================
# Layer 4: AI/LLM Observability
# ===========================

# Helicone API Key (LLM Gateway & Cost Tracking)
# Get from: https://helicone.ai → Settings → API Keys
HELICONE_API_KEY=

# Langfuse Keys (LLM Tracing & Prompt Management)
# Get from: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ===========================
# Layer 2: Data Encryption
# ===========================

# AES-256 Encryption Key for Stripe secret keys (REQUIRED for production)
# Used by Supabase Edge Functions to encrypt/decrypt Stripe keys
# Generate with: openssl rand -hex 32
# Also set in Supabase Dashboard → Database → Configuration Parameters as:
#   app.settings.stripe_encryption_key = '<same-value>'
ENCRYPTION_KEY=

# ===========================
# Layer 3: API Token Security
# ===========================

# Delivery Token Secret (REQUIRED for delivery link tokens)
# Generate with: openssl rand -hex 32
# Must be set in all environments — no fallback allowed
DELIVERY_TOKEN_SECRET=

# WhatsApp Health Check API Key (optional, secures GET /api/whatsapp)
# Generate with: openssl rand -hex 16
WHATSAPP_HEALTH_API_KEY=

# ===========================
# Additional Security Notes
# ===========================
#
# Critical Secrets (already in .env.example):
# - SUPABASE_SERVICE_ROLE_KEY (NEVER expose client-side)
# - NEO4J_PASSWORD
# - STRIPE_SECRET_KEY
# - META_WHATSAPP_TOKEN
# - RAILWAY_TOKEN
# - N8N_ENCRYPTION_KEY
#
# Public Keys (safe to expose in client-side code):
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_STRIPE_PUBLISHABLE_KEY
# - VITE_SENTRY_DSN (frontend only)
#
# Verify your environment with:
# npm run check-env
